# Registry
VITE_REGISTRY_URL=http://localhost:8090

# Azure MSAL + auth-service (required for production auth)
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_API_SCOPE=
VITE_AUTH_SERVICE_URL=http://localhost:8080

# WARNING: If CLIENT_ID, TENANT_ID, or AUTH_SERVICE_URL is omitted, @mcas/auth-client
# runs in NoAuth / DEV mode (not production-ready). Do not deploy without full MSAL config.
